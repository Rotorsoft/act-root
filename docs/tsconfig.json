{
  // This file is not used in compilation. It is here just for a nice editor experience.
  "extends": "../tsconfig.eslint.json",
  "compilerOptions": {
    "paths": {
      "@rotorsoft/act": ["../libs/act/src/index.ts"],
      "@rotorsoft/act-diagram": ["../libs/act-diagram/src/index.ts"],
      "@rotorsoft/act-http/webhook": ["../libs/act-http/src/webhook/index.ts"],
      "@rotorsoft/act-http/sse": ["../libs/act-http/src/sse/index.ts"],
      "@rotorsoft/act-patch": ["../libs/act-patch/src/index.ts"],
      "@rotorsoft/act-pg": ["../libs/act-pg/src/index.ts"],
      "@rotorsoft/act-pino": ["../libs/act-pino/src/index.ts"],
      "@rotorsoft/act-sqlite": ["../libs/act-sqlite/src/index.ts"],
      "@rotorsoft/act-tck": ["../libs/act-tck/src/index.ts"]
    }
  },
  "include": [
    "../libs/act/src/**/*",
    "../libs/act-diagram/src/**/*",
    "../libs/act-http/src/**/*",
    "../libs/act-patch/src/**/*",
    "../libs/act-pg/src/**/*",
    "../libs/act-pino/src/**/*",
    "../libs/act-sqlite/src/**/*",
    "../libs/act-tck/src/**/*"
  ],
  "exclude": ["../packages/**"]
}
