{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build:all": "typedoc --options typedoc.json && docusaurus build",
    "snippets:extract": "node scripts/check-snippets.mjs",
    "check:snippets": "node scripts/check-snippets.mjs && tsc --noEmit -p tsconfig.snippets.json",
    "check:snippets:selftest": "node scripts/check-snippets.mjs --self-test",
    "swizzle": "docusaurus swizzle",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@stackblitz/sdk": "^1.11.1",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.10.2",
    "@docusaurus/faster": "^3.10.2",
    "@rotorsoft/act": "workspace:^",
    "zod": "^4.4.3",
    "@docusaurus/module-type-aliases": "3.10.2",
    "@docusaurus/preset-classic": "^3.10.2",
    "@docusaurus/tsconfig": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "docusaurus-plugin-typedoc": "^1.4.2",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "~6.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=22.23.1"
  }
}
