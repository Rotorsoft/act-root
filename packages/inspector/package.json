  "description": "Act event sourcing observatory — inspect, query, and visualize events in Act stores",
  "type": "module",
  "author": {
    "name": "rotorsoft",
    "email": "rotorsoft@outlook.com"
  },
  "scripts": {
    "dev:server": "tsx watch --env-file=.env src/server/server.ts",
