    "@trpc/server": "11.12.1",
    "cors": "^2.8.6",
    "d3-scale": "^4.0.2",
    "d3-time": "^3.1.0",
    "lucide-react": "^0.577.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.3",
