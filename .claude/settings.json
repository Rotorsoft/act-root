{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(node -e:*)",
      "Bash(npm view:*)",
      "Bash(npm search:*)",
      "Bash(tsx:*)",
      "Bash(LOG_LEVEL=*)",
      "Bash(NODE_ENV=*)",
      "Bash(RUN_NOTIFY_REPORT=* pnpm:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(xargs:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(jq:*)",
      "Bash(tee:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(rm -rf dist:*)",
      "Bash(rm -rf coverage:*)",
      "Bash(rm -rf *.tsbuildinfo:*)",
      "Bash(curl http://localhost*)",
      "Bash(curl http://127.0.0.1*)",
      "Bash(curl https://api.github.com*)",
      "Bash(curl https://registry.npmjs.org*)",
      "Bash(curl --version)",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(pg_isready:*)",
      "Bash(PGPASSWORD=postgres psql:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "WebFetch(domain:rotorsoft.github.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:typedoc.org)",
      "WebFetch(domain:typedoc-plugin-markdown.org)",
      "WebFetch(domain:docusaurus.io)",
      "WebFetch(domain:eventmodeling.org)",
      "WebFetch(domain:event-driven.io)",
      "WebFetch(domain:martendb.io)",
      "WebFetch(domain:typst.app)",
      "WebFetch(domain:cdn.jsdelivr.net)",
      "WebSearch"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --no-verify*)",
      "Bash(git reset --hard*)",
      "Bash(git filter-branch*)",
      "Bash(git config user*)",
      "Bash(git commit --no-verify*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf ${HOME}*)",
      "Bash(gh repo delete*)",
      "Bash(gh release delete*)",
      "Bash(gh secret*)",
      "Bash(gh auth logout*)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Bash(yarn publish*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck-touched.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-summary.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-context.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
