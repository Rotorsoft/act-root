{
  "name": "@rotorsoft/act-otel",
  "type": "module",
  "version": "0.0.0",
  "description": "Prometheus metrics bridge for @rotorsoft/act lifecycle events",
  "keywords": [
    "typescript",
    "prometheus",
    "metrics",
    "observability",
    "event-sourcing"
  ],
  "author": "rotorsoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rotorsoft/act-root.git",
    "directory": "libs/act-otel"
  },
  "homepage": "https://github.com/rotorsoft/act-root/tree/master/libs/act-otel#readme",
  "bugs": {
    "url": "https://github.com/rotorsoft/act-root/issues"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/@types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/@types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.23.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "types": "tsc --build tsconfig.build.json --emitDeclarationOnly",
    "build": "pnpm clean && tsup && pnpm types"
  },
  "peerDependencies": {
    "@rotorsoft/act": "workspace:^",
    "prom-client": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rotorsoft/act-tck": "workspace:^",
    "prom-client": "^15.1.3"
  }
}
