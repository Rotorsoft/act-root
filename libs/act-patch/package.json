{
  "name": "@rotorsoft/act-patch",
  "type": "module",
  "version": "1.2.5",
  "description": "Immutable deep-merge patch utility for act apps",
  "keywords": [
    "typescript",
    "immer",
    "deep-merge",
    "rfc-7396",
    "json-merge-patch",
    "immutable"
  ],
  "author": "rotorsoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rotorsoft/act-root.git",
    "directory": "libs/act-patch"
  },
  "homepage": "https://github.com/rotorsoft/act-root/tree/master/libs/act-patch#readme",
  "bugs": {
    "url": "https://github.com/rotorsoft/act-root/issues"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/@types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/@types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.23.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "types": "tsc --build tsconfig.build.json --emitDeclarationOnly",
    "build": "pnpm clean && tsup && pnpm types",
    "mutation": "stryker run"
  },
  "dependencies": {},
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1"
  }
}
