{
  "name": "@rotorsoft/act-sse",
  "type": "module",
  "version": "1.2.3",
  "description": "Incremental state broadcast over SSE for act apps",
  "keywords": [
    "typescript",
    "sse",
    "server-sent-events",
    "real-time",
    "eventsource"
  ],
  "author": "rotorsoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rotorsoft/act-root.git",
    "directory": "libs/act-sse"
  },
  "homepage": "https://github.com/rotorsoft/act-root/tree/master/libs/act-sse#readme",
  "bugs": {
    "url": "https://github.com/rotorsoft/act-root/issues"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/@types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/@types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=24.16.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "types": "tsc --build tsconfig.build.json --emitDeclarationOnly",
    "build": "pnpm clean && tsup && pnpm types"
  },
  "dependencies": {
    "@rotorsoft/act-patch": "workspace:^"
  }
}
