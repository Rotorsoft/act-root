{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUncheckedSideEffectImports": true,
    "verbatimModuleSyntax": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@rotorsoft/*": ["./*/src/index.ts"]
    }
  }
}
